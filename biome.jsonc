{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/react"],
  "files": {
    "includes": [
      "!**/dist",
      "!**/dist-cli",
      "!**/node_modules",
      "!**/src-tauri/target"
    ]
  },
  "overrides": [
    {
      "includes": ["packages/ide/src-tauri/**"],
      "linter": {
        "enabled": false
      },
      "formatter": {
        "enabled": false
      }
    }
  ]
}
